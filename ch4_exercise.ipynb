   "source": [
    "from jupyturtle import make_turtle, forward, left, right, penup, pendown\n",
    "make_turtle()\n",
    "def polygon(n, length):\n",
    "    angle = 360 / n\n",
    "    for i in range(n):\n",
    "        forward(length)\n",
    "        left(angle)\n",
    "\n",
    "polygon(20, 10)\n",
    "\n",
    "\n",
